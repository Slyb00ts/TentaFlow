{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tentaflow.dev/schemas/service-manifest-v1.json",
  "title": "TentaFlow Service Manifest",
  "description": "Manifest TOML opisujacy jeden silnik wnioskowania (engine) i jego warianty deploymentu.",
  "type": "object",
  "required": ["engine", "variant"],
  "additionalProperties": false,
  "properties": {
    "engine": { "$ref": "#/$defs/engine" },
    "variant": {
      "type": "array",
      "minItems": 1,
      "description": "Lista wariantow deploymentu (TOML: [[variant]]).",
      "items": { "$ref": "#/$defs/variant" }
    },
    "model_preset": {
      "type": "array",
      "description": "Opcjonalna lista rekomendowanych modeli (TOML: [[model_preset]]).",
      "items": { "$ref": "#/$defs/model_preset" }
    }
  },
  "$defs": {
    "category": {
      "type": "string",
      "enum": [
        "llm", "stt", "tts", "embeddings", "reranker",
        "vision", "image-gen", "video-gen", "music-gen",
        "model-3d-gen", "agents", "tools"
      ],
      "description": "Kategoria uslugi udostepnianej przez silnik."
    },
    "api": {
      "type": "string",
      "enum": [
        "openai-compatible", "ollama-native",
        "sherpa-tts", "sherpa-stt", "comfyui", "custom"
      ],
      "description": "Protokol API udostepniany przez silnik."
    },
    "deploy_mode": {
      "type": "string",
      "enum": ["native", "docker", "python-bundle", "embedded", "external"],
      "description": "Tryb deploymentu wariantu."
    },
    "target_os": {
      "type": "string",
      "enum": ["linux", "macos", "windows", "ios", "android"]
    },
    "target_os_value": {
      "oneOf": [
        { "$ref": "#/$defs/target_os" },
        {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/target_os" }
        }
      ],
      "description": "Pojedynczy OS lub lista OS-ow."
    },
    "target_arch": {
      "type": "string",
      "enum": ["x86_64", "aarch64", "any"]
    },
    "target_arch_value": {
      "oneOf": [
        { "$ref": "#/$defs/target_arch" },
        {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/target_arch" }
        }
      ]
    },
    "gpu_backend": {
      "type": "string",
      "enum": ["cpu", "cuda", "rocm", "vulkan", "metal", "mlx", "xpu"]
    },
    "gpu_backend_value": {
      "oneOf": [
        { "$ref": "#/$defs/gpu_backend" },
        {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/gpu_backend" }
        }
      ]
    },
    "status": {
      "type": "string",
      "enum": ["stable", "experimental", "planned", "deprecated"]
    },
    "kebab_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Identyfikator kebab-case: tylko male litery, cyfry i pojedyncze myslniki."
    },
    "engine": {
      "type": "object",
      "required": [
        "id", "category", "name",
        "description_pl", "description_en",
        "homepage", "license", "api",
        "default_port", "version"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/kebab_id", "description": "Unikalny ID silnika (kebab-case)." },
        "category": { "$ref": "#/$defs/category" },
        "name": { "type": "string", "minLength": 1, "description": "Nazwa wyswietlana w GUI." },
        "description_pl": { "type": "string", "minLength": 1, "maxLength": 200, "description": "Opis po polsku." },
        "description_en": { "type": "string", "minLength": 1, "maxLength": 200, "description": "Opis po angielsku." },
        "homepage": { "type": "string", "format": "uri", "description": "Strona projektu." },
        "license": { "type": "string", "minLength": 1, "description": "Identyfikator SPDX licencji." },
        "api": { "$ref": "#/$defs/api" },
        "default_port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "Domyslny port silnika."
        },
        "version": { "type": "string", "minLength": 1, "description": "Wersja referencyjna silnika." },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Etykiety opisowe dla wyszukiwarki."
        },
        "also_serves": {
          "type": "array",
          "items": { "$ref": "#/$defs/category" },
          "description": "Inne kategorie obslugiwane przez ten sam silnik."
        },
        "docs_url": { "type": "string", "format": "uri", "description": "Adres dokumentacji." },
        "icon": { "type": "string", "description": "Klucz ikony w katalogu wwwroot." }
      }
    },
    "variant": {
      "type": "object",
      "required": ["id", "deploy_mode", "target_os", "target_arch", "gpu_backend", "status"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/kebab_id" },
        "deploy_mode": { "$ref": "#/$defs/deploy_mode" },
        "target_os": { "$ref": "#/$defs/target_os_value" },
        "target_arch": { "$ref": "#/$defs/target_arch_value" },
        "gpu_backend": { "$ref": "#/$defs/gpu_backend_value" },
        "status": { "$ref": "#/$defs/status" },
        "vram_gb_min": { "type": "integer", "minimum": 0, "maximum": 65535 },
        "ram_gb_min": { "type": "integer", "minimum": 0, "maximum": 65535 },
        "disk_gb_min": { "type": "integer", "minimum": 0, "maximum": 65535 },
        "notes_pl": { "type": "string" },
        "notes_en": { "type": "string" },
        "build": { "$ref": "#/$defs/variant_build" },
        "download": { "$ref": "#/$defs/variant_download" },
        "feature_flag": { "$ref": "#/$defs/variant_feature_flag" },
        "detection": { "$ref": "#/$defs/variant_detection" }
      },
      "allOf": [
        {
          "if": { "properties": { "deploy_mode": { "const": "docker" } } },
          "then": { "required": ["build"] }
        },
        {
          "if": { "properties": { "deploy_mode": { "const": "python-bundle" } } },
          "then": {
            "required": ["build"],
            "not": { "anyOf": [
              { "required": ["feature_flag"] },
              { "required": ["detection"] }
            ]}
          }
        },
        {
          "if": { "properties": { "deploy_mode": { "const": "native" } } },
          "then": {
            "required": ["build"],
            "not": { "anyOf": [
              { "required": ["feature_flag"] },
              { "required": ["detection"] }
            ]}
          }
        },
        {
          "if": { "properties": { "deploy_mode": { "const": "embedded" } } },
          "then": {
            "required": ["feature_flag"],
            "not": { "anyOf": [
              { "required": ["build"] },
              { "required": ["download"] },
              { "required": ["detection"] }
            ]}
          }
        },
        {
          "if": { "properties": { "deploy_mode": { "const": "external" } } },
          "then": {
            "required": ["detection"],
            "not": { "anyOf": [
              { "required": ["build"] },
              { "required": ["download"] },
              { "required": ["feature_flag"] }
            ]}
          }
        }
      ]
    },
    "variant_build": {
      "type": "object",
      "required": ["context_path"],
      "additionalProperties": false,
      "description": "Definicja lokalnego buildu (Dockerfile, skrypt natywny, bundle Python).",
      "properties": {
        "context_path": {
          "type": "string",
          "minLength": 1,
          "description": "Sciezka wzgledem tentaflow-containers/. Katalog musi istniec."
        },
        "dockerfile": {
          "type": "string",
          "default": "Dockerfile",
          "description": "Nazwa Dockerfile (tylko dla deploy_mode = docker)."
        },
        "build_args": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Argumenty --build-arg lub zmienne srodowiskowe."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Lokalne tagi obrazu / artefaktu."
        }
      }
    },
    "variant_download": {
      "type": "object",
      "required": ["image"],
      "additionalProperties": false,
      "description": "Prebuilt artefakt do pobrania (typowo wariant Pro).",
      "properties": {
        "image": {
          "type": "string",
          "minLength": 1,
          "description": "Referencja OCI z tagiem."
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "Digest obrazu w formacie sha256:<64hex>."
        },
        "size_mb": {
          "type": "integer",
          "minimum": 0,
          "description": "Rozmiar do pobrania w MB."
        },
        "license_required": {
          "type": "string",
          "enum": ["pro", "enterprise"],
          "default": "pro",
          "description": "Wymagana licencja do pobrania artefaktu."
        },
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Czy pobranie jest aktywne (false = infrastruktura tylko, brak realnego obrazu)."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "enabled": { "const": true } }, "required": ["enabled"] },
          "then": { "required": ["digest"] }
        }
      ]
    },
    "variant_feature_flag": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "description": "Cargo feature aktywujacy silnik w binarce TentaFlow (deploy_mode = embedded).",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Nazwa Cargo feature, np. inference-llamacpp."
        }
      }
    },
    "variant_detection": {
      "type": "object",
      "required": ["binary", "endpoint"],
      "additionalProperties": false,
      "description": "Sposob wykrycia zewnetrznego serwisu (deploy_mode = external).",
      "properties": {
        "binary": {
          "type": "string",
          "minLength": 1,
          "description": "Nazwa binarki w PATH, np. ollama."
        },
        "endpoint": {
          "type": "string",
          "format": "uri",
          "description": "Adres health check."
        },
        "health_path": {
          "type": "string",
          "default": "/",
          "description": "Sciezka health check (default /)."
        }
      }
    },
    "model_preset": {
      "type": "object",
      "required": ["id", "display_name", "repo"],
      "additionalProperties": false,
      "description": "Rekomendowany model dla silnika.",
      "properties": {
        "id": { "$ref": "#/$defs/kebab_id" },
        "display_name": { "type": "string", "minLength": 1 },
        "repo": { "type": "string", "minLength": 1, "description": "Repo HuggingFace, URL GGUF, repo MLX itp." },
        "quantization": { "type": "string", "description": "Kwantyzacja, np. Q4_K_M, fp16, int4." },
        "vram_gb_min": { "type": "integer", "minimum": 0, "maximum": 65535 },
        "recommended": { "type": "boolean", "default": false }
      }
    }
  }
}

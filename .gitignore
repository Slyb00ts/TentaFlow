# =============================================================================
# Artefakty kompilacji
# =============================================================================
target/
obj/
bin/
*.o
*.a
*.so
*.dylib
*.dll
*.exe
*.wasm

# Swift Package Manager + xcodebuild (mlx-swift bridge build outputs)
.build/
build-xcode/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
DerivedData/

# Wygenerowany manifest serwisow dla GUI (build.rs produkuje przy kompilacji)
tentaflow-core/www/js/generated/
tentaflow-core/wwwroot/js/generated/

# Wygenerowany cbindgen header dla .NET P/Invoke
tentaflow-client/native/include/

# =============================================================================
# Bazy danych
# =============================================================================
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# =============================================================================
# Certyfikaty i klucze
# =============================================================================
certs/
*.pem
*.pfx
*.p12
*.key
*.crt
*.cer

# =============================================================================
# Konfiguracja lokalna (generowana przy starcie)
# =============================================================================
config.toml
*.local.toml
# Exception: .cargo/config.toml MUSI byc w repo zeby globalne build
# settings (jobs, profile defaults, linker, sccache) zadzialaly dla
# wszystkich. Nadpisuje regule `config.toml` powyzej.
!.cargo/config.toml
.env
.env.*
!.env.example

# =============================================================================
# IDE / Edytory
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# Ralph Loop (stan runtime)
# =============================================================================
.ralph-state.json
.ralph-prompt-runtime.md

# =============================================================================
# Logi
# =============================================================================
*.log
logs/

# =============================================================================
# .NET artefakty
# =============================================================================
*.nupkg
*.snupkg
project.assets.json
*.nuget.*
*.AssemblyInfo.cs

# =============================================================================
# Rust specyficzne
# =============================================================================
**/*.rs.bk
Cargo.lock

# Wyjatki — Cargo.lock dla binarek (nie bibliotek)
!tentaflow/Cargo.lock
!tentaflow-desktop/Cargo.lock
!tentaflow-desktop/macos/Cargo.lock
!tentaflow-mobile/Cargo.lock
!tentaflow-memory/Cargo.lock
!tentaflow-containers/*/Cargo.lock

# =============================================================================
# WASM build artefakty (addony kompilowane lokalnie)
# =============================================================================
tentaflow-core/addons/*/target/

# =============================================================================
# Test fixtures (regenerowane lokalnie przez ffmpeg — patrz README)

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>ai.tentaflow</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/tentaflow</string>
    <string>--config</string>
    <string>/Users/Shared/TentaFlow/config.toml</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key><false/>
    <key>Crashed</key><true/>
  </dict>
  <key>StandardOutPath</key><string>/Users/Shared/TentaFlow/tentaflow.log</string>
  <key>StandardErrorPath</key><string>/Users/Shared/TentaFlow/tentaflow.err.log</string>
  <key>WorkingDirectory</key><string>/Users/Shared/TentaFlow</string>
</dict>
</plist>
